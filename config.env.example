# AI Curtain Control — runtime config.
# Copy to config.env and edit. Loaded by systemd (EnvironmentFile) and read by
# app.py as argparse defaults (CLI flags still override).

CURTAIN_PROFILE=hand_near    # hand_near (근거리 손) | body_far (원거리 전신)
CURTAIN_CONF=0.3             # detection confidence 0.1-0.8
CURTAIN_WIDTH=1280
CURTAIN_HEIGHT=720
CURTAIN_FPS=30
CURTAIN_PORT=8080
CURTAIN_QUALITY=75           # MJPEG JPEG quality 1-100
CURTAIN_REMOTE=0             # 1 = auto-start Cloudflare quick tunnel at boot
CURTAIN_BLE=0                # 1 = start BLE remote peripheral (Flutter app)
CURTAIN_AUTH=1               # 0 = disable login (development only)
