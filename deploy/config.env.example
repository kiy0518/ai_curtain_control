# AI Curtain Control — 런타임 설정 (systemd EnvironmentFile)
# 사용: deploy/install.sh 가 이 파일을 config.env 로 복사. 값 변경 후
#   sudo systemctl restart ai-curtain
# 주의: 프로파일/신뢰도/반전 등 대시보드에서 바꾼 값은 SQLite에 저장되어
#   재부팅에도 유지되며, DB 값이 아래 기본값보다 우선합니다.

# 로그인: 0=비활성(개발 편의), 1=관리자 로그인 사용
CURTAIN_AUTH=0

# 시작 프로파일 (DB에 저장된 값이 있으면 그게 우선)
# CURTAIN_PROFILE=hand_near        # hand_near | body_far | body_motion
# CURTAIN_CONF=0.3
# CURTAIN_PORT=8080
# CURTAIN_HOST=0.0.0.0
# CURTAIN_WIDTH=1280
# CURTAIN_HEIGHT=720
# CURTAIN_FPS=30
# CURTAIN_QUALITY=75

# 원격 접속(cloudflared) / BLE 리모컨 서버: 1=켜기
# CURTAIN_REMOTE=1
# CURTAIN_BLE=1
